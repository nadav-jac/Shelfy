{
  "name": "shelfy",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "npm install --prefix shelfy/backend && npm install --prefix shelfy/frontend",
    "build": "npm run build --prefix shelfy/frontend",
    "start": "node shelfy/backend/server.js",
    "dev:api": "npm run dev --prefix shelfy/backend",
    "dev:ui": "npm run dev --prefix shelfy/frontend"
  }
}
